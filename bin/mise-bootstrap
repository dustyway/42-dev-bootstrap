#!/usr/bin/env bash
# mise-bootstrap — restore mise runtimes + per-tool extras after a sgoinfre
# wipe. Safe to run every login (idempotent: no-op when everything is already
# in place). Auto-detects which tools are configured and only sets up what's
# relevant.
#
# Pair with ~/.config/mise/config.toml (tool pins) and
# ~/Apps/etc/npm-globals.txt (one npm package per line).

set -euo pipefail

# Pin storage to the school's persistent network share + local disk. Export
# these here too (not only in ~/.profile) so the script works correctly even
# if invoked from a shell that didn't source .profile — otherwise mise would
# fall back to ~/.local/share/mise and blow the $HOME 5 GB quota.
export MISE_DATA_DIR="/sgoinfre/goinfre/Perso/${USER}/mise-data"
export MISE_CACHE_DIR="/goinfre/${USER}/mise-cache"
mkdir -p "$MISE_DATA_DIR" "$MISE_CACHE_DIR"

# Returns 0 if the given tool is configured in any active mise config file.
has_tool() { MISE_DATA_DIR="$MISE_DATA_DIR" mise current "$1" &>/dev/null; }

# ---------------------------------------------------------------------------
# 1. Erlang — wx/observer support
#    The core mise erlang backend ships a pre-built binary linked against
#    wx 3.0, which doesn't exist on these machines. Use asdf-erlang instead so
#    kerl compiles from source with KERL_CONFIGURE_OPTIONS pointing at our
#    sgoinfre wx 3.2.x build. wx-bootstrap downloads that build from CI.
# ---------------------------------------------------------------------------
WX_HOME=""
if has_tool erlang; then
    _wx_bootstrap="$(cd "$(dirname "$0")" && pwd)/wx-bootstrap"
    [[ -x "$_wx_bootstrap" ]] || _wx_bootstrap="$(command -v wx-bootstrap 2>/dev/null || true)"

    if [[ -x "$_wx_bootstrap" ]]; then
        if WX_HOME=$("$_wx_bootstrap" "${WX_VERSION:-3.2.6}"); then
            # kerl reads ~/.kerlrc because mise doesn't propagate exported env
            # vars into plugin install subprocesses.
            export KERL_CONFIGURE_OPTIONS="--with-wx-config=${WX_HOME}/bin/wx-config${KERL_CONFIGURE_OPTIONS:+ ${KERL_CONFIGURE_OPTIONS}}"
            printf 'KERL_CONFIGURE_OPTIONS="%s"\n' "$KERL_CONFIGURE_OPTIONS" > "$HOME/.kerlrc"
            export LD_LIBRARY_PATH="${WX_HOME}/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
        else
            echo "[mise-bootstrap] WARNING: wx-bootstrap failed; :observer will not work" >&2
        fi
    fi
    unset _wx_bootstrap

    # asdf-erlang compiles from source via kerl; the core backend does not.
    mise plugin add erlang https://github.com/asdf-vm/asdf-erlang 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# 2. Install all mise-pinned runtimes that are missing.
# ---------------------------------------------------------------------------
mise install

# ---------------------------------------------------------------------------
# 3. Activate mise env so subsequent commands resolve the right binaries.
#    mise activate is shell-hook-based and doesn't work in non-interactive
#    scripts; mise env is the script-safe equivalent.
# ---------------------------------------------------------------------------
eval "$(mise env -s bash)"

# ---------------------------------------------------------------------------
# 4. Elixir — Mix archives + IEx observer filter
# ---------------------------------------------------------------------------
if has_tool elixir && command -v mix >/dev/null 2>&1; then
    # Hex + rebar are per-Elixir-version; a version bump otherwise prompts
    # interactively on the next mix deps.get.
    mix local.hex --if-missing --force >/dev/null 2>&1 || true
    mix local.rebar --if-missing --force >/dev/null 2>&1 || true
    if ! mix archive 2>/dev/null | grep -q '^\* phx_new'; then
        echo "[mise-bootstrap] installing phx_new archive"
        mix archive.install hex phx_new --force
    fi
fi

# ---------------------------------------------------------------------------
# 5. Node — global npm packages
# ---------------------------------------------------------------------------
if has_tool node && command -v npm >/dev/null 2>&1; then
    GLOBALS="$HOME/Apps/etc/npm-globals.txt"
    if [[ -s "$GLOBALS" ]]; then
        missing=()
        npm_prefix=$(npm prefix -g)
        while IFS= read -r line; do
            [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
            case "$line" in
                @*/*@*)  name="${line%@*}" ;;
                @*/*)    name="$line" ;;
                *@*)     name="${line%@*}" ;;
                *)       name="$line" ;;
            esac
            [[ -d "$npm_prefix/lib/node_modules/$name" ]] || missing+=("$line")
        done < "$GLOBALS"
        if (( ${#missing[@]} > 0 )); then
            echo "[mise-bootstrap] installing missing npm globals: ${missing[*]}"
            npm install -g "${missing[@]}"
        fi
    fi
fi

# ---------------------------------------------------------------------------
# 6. Erlang/Elixir shell config — wx LD_LIBRARY_PATH + IEx noise filter
#    Written once into ~/.profile and ~/.iex.exs; keyed on marker comments so
#    re-runs are no-ops.
# ---------------------------------------------------------------------------
if [[ -n "$WX_HOME" ]]; then
    # ~/.profile: wx shared libs must be on LD_LIBRARY_PATH for :observer.
    if [[ -f "$HOME/.profile" ]] && ! grep -q "# wx-sgoinfre LD_LIBRARY_PATH" "$HOME/.profile"; then
        cat >> "$HOME/.profile" <<'WXPROFILE'

# wx-sgoinfre LD_LIBRARY_PATH — added by mise-bootstrap for :observer support
_wx_lib="/sgoinfre/goinfre/Perso/${USER}/wx/3.2.6/lib"
[[ -d "$_wx_lib" ]] && export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+${LD_LIBRARY_PATH}:}${_wx_lib}"
unset _wx_lib
WXPROFILE
    fi
fi

if has_tool erlang || has_tool elixir; then
    # ~/.iex.exs: silence the noisy GTK style-context warnings wx emits on
    # GTK3 — cosmetic mismatch with wxWidgets 3.2, no actionable information.
    if ! grep -q "# wx-gtk-noise-filter" "$HOME/.iex.exs" 2>/dev/null; then
        cat >> "$HOME/.iex.exs" <<'WXIEX'

# wx-gtk-noise-filter — added by mise-bootstrap
:logger.add_primary_filter(:suppress_wx_gtk_noise, {
  fn event, _ ->
    try do
      msg_str =
        case event[:msg] do
          {:string, m} when is_binary(m) -> m
          {:string, m} -> :erlang.iolist_to_binary(m)
          {fmt, args} when is_list(args) -> :erlang.iolist_to_binary(:io_lib.format(fmt, args))
          _ -> ""
        end
      if String.contains?(msg_str, "GTK:"), do: :stop, else: :ignore
    rescue
      _ -> :ignore
    end
  end,
  nil
})
WXIEX
    fi
fi

# ---------------------------------------------------------------------------
# 7. JetBrains — sync Elixir/Erlang SDK home paths with mise versions.
#    Safe no-op when the IDE isn't installed or versions already match.
# ---------------------------------------------------------------------------
if (has_tool elixir || has_tool erlang) && [[ -x "$HOME/Apps/bin/jb-sync-elixir-sdk" ]]; then
    "$HOME/Apps/bin/jb-sync-elixir-sdk" || true
fi
