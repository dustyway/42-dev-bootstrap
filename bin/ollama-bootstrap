#!/usr/bin/env bash
# ollama-bootstrap — manage user-private ollama models on sgoinfre.
#
# 42 cluster machines ship an apt-installed ollama daemon at
# /bin/ollama on the default port (11434), with a system-owned model
# store. We don't fight it: instead we run a *second* daemon under the
# user's account on port 11435, pointed at $SGO/ollama/models so the
# big files live where they fit. Setting OLLAMA_HOST=127.0.0.1:11435
# in the shell makes any ollama client (system or otherwise) talk to
# the user's daemon — the protocol is just HTTP, the binary doesn't
# matter, only the host.
#
# This script does NOT install an ollama binary — it relies on the
# cluster's `/bin/ollama` (currently 0.13.3 on jammy). It does:
#   - ensure $SGO/ollama/models exists
#   - drop a `~/bin/ollama-serve` launcher that starts the user daemon
#     on port 11435 with OLLAMA_MODELS pointed at sgoinfre
#   - re-pull anything from ~/Apps/etc/ollama-models.txt that's missing
#     (heals after a /sgoinfre wipe)
#
# Add this to ~/.profile (also covered by shell/profile.snippet):
#   export OLLAMA_HOST=127.0.0.1:11435
#
# Then on each login (or via ~/.zprofile):
#   ollama-serve            # idempotent, no-op if already running
#   ollama run qwen2.5-coder:7b
#
# Default model: qwen2.5-coder:7b (~4.7 GB Q4_K_M) — strongest small
# open coding model that fits sgoinfre with headroom.

set -euo pipefail

OLLAMA_BIN="${OLLAMA_BIN:-/bin/ollama}"
USER_PORT="${OLLAMA_USER_PORT:-11435}"
BOOTSTRAP_PORT="${OLLAMA_BOOTSTRAP_PORT:-11500}"  # transient daemon for missing-model pulls

if [[ ! -x "$OLLAMA_BIN" ]]; then
    echo "[ollama-bootstrap] no ollama binary at $OLLAMA_BIN" >&2
    echo "[ollama-bootstrap] override with OLLAMA_BIN=/path/to/ollama, or fall back" >&2
    echo "[ollama-bootstrap] to a self-installed copy (see git history of this script)." >&2
    exit 1
fi

SGO="$(ls -d /sgoinfre/goinfre/Perso/*"${USER}"* 2>/dev/null | head -n1)"
[[ -z "$SGO" ]] && { echo "[ollama-bootstrap] sgoinfre path not found for $USER" >&2; exit 1; }

MODELS_DIR="$SGO/ollama/models"
MODELS_FILE="$HOME/Apps/etc/ollama-models.txt"

mkdir -p "$MODELS_DIR" "$HOME/Apps/etc" "$HOME/bin"

# Seed the desired-models list on first run.
if [[ ! -e "$MODELS_FILE" ]]; then
    cat > "$MODELS_FILE" <<'EOF'
# Desired ollama models, one per line. Lines starting with `#` ignored.
# `ollama-bootstrap` re-pulls anything missing from $OLLAMA_MODELS.
qwen2.5-coder:7b
EOF
    echo "[ollama-bootstrap] seeded $MODELS_FILE"
fi

# Launcher: starts the user's daemon on $USER_PORT with the right
# OLLAMA_MODELS. Idempotent — bails if a daemon already responds.
cat > "$HOME/bin/ollama-serve" <<EOF
#!/usr/bin/env bash
set -euo pipefail
export OLLAMA_MODELS="$MODELS_DIR"
export OLLAMA_HOST="127.0.0.1:$USER_PORT"
LOG="/tmp/ollama-\$USER.log"
if curl -fsS --max-time 1 "http://\$OLLAMA_HOST/api/tags" >/dev/null 2>&1; then
    echo "[ollama-serve] already running on \$OLLAMA_HOST"
    exit 0
fi
nohup "$OLLAMA_BIN" serve >>"\$LOG" 2>&1 &
disown
echo "[ollama-serve] daemon starting on \$OLLAMA_HOST (log: \$LOG)"
EOF
chmod +x "$HOME/bin/ollama-serve"

# ── Ensure desired models are present ──────────────────────────────────────
mapfile -t WANT < <(grep -vE '^\s*(#|$)' "$MODELS_FILE" || true)
(( ${#WANT[@]} == 0 )) && exit 0

# Spin up a transient daemon on $BOOTSTRAP_PORT for the pulls. Distinct
# from $USER_PORT so we don't fight a long-running user daemon.
export OLLAMA_MODELS="$MODELS_DIR"
export OLLAMA_HOST="127.0.0.1:$BOOTSTRAP_PORT"

"$OLLAMA_BIN" serve >/dev/null 2>&1 &
SERVE_PID=$!
trap 'kill "$SERVE_PID" 2>/dev/null || true' EXIT

for _ in $(seq 1 30); do
    "$OLLAMA_BIN" list >/dev/null 2>&1 && break
    sleep 0.5
done

have="$("$OLLAMA_BIN" list 2>/dev/null | tail -n +2 | awk '{print $1}')"
for m in "${WANT[@]}"; do
    if grep -Fxq -- "$m" <<< "$have"; then
        continue
    fi
    echo "[ollama-bootstrap] pulling $m (this may take a while)"
    "$OLLAMA_BIN" pull "$m"
done
