#!/usr/bin/env bash
# graphviz-bootstrap — install graphviz (`dot`, `neato`, …) without sudo.
#
# 42 cluster machines run Ubuntu 22.04 but users have no sudo, so
# `apt install graphviz` is out. mise has no graphviz plugin. Building
# from source would pull in cairo/pango/libpng/freetype — a chore.
#
# Trick: `apt-get download` works without root — it just fetches the
# .deb from the apt index. We extract the .debs with `dpkg-deb -x` into
# a private prefix, then drop wrapper scripts into ~/bin that set
# LD_LIBRARY_PATH and GVBINDIR so the binaries find their libs and
# layout/render plugins under the non-standard prefix. graphviz's
# plugin .so files dlopen cairo/pango/etc. from the system at runtime,
# which the cluster machines already have.
#
# Usage:  graphviz-bootstrap [VERSION]
#   VERSION must match a graphviz package version in the apt index
#   (default targets Ubuntu 22.04 jammy).
#
# ─── Placement (same reasoning as inotify-tools-bootstrap) ──────────────────
# App tree → $SGO/graphviz/<version>/   persistent on sgoinfre
# Cached .debs → $SGO/.cache/graphviz-<version>/
# Wrappers → ~/bin/dot, ~/bin/neato, …  (not symlinks: need env tweaks)
# ──────────────────────────────────────────────────────────────────────────────

set -euo pipefail

VERSION="${1:-2.42.2-6}"

SGO="$(ls -d /sgoinfre/goinfre/Perso/*"${USER}"* 2>/dev/null | head -n1)"
[[ -z "$SGO" ]] && { echo "[graphviz-bootstrap] sgoinfre path not found for $USER" >&2; exit 1; }

APP_HOME="$SGO/graphviz/${VERSION}"
DEB_CACHE="$SGO/.cache/graphviz-${VERSION}"
VERSION_MARKER="$APP_HOME/.graphviz-bootstrap-version"

# graphviz + the runtime libraries it links against on jammy. The
# graphviz .deb itself ships the layout/render plugins under
# /usr/lib/x86_64-linux-gnu/graphviz/ which dlopen cairo/pango/libpng/
# freetype/fontconfig from the system — no need to vendor those.
LIB_PACKAGES=(libgvc6 libcgraph6 libcdt5 libpathplan4 libxdot4 libgts-0.7-5 libltdl7)

mkdir -p "$DEB_CACHE" "$SGO/graphviz"

installed=""
[[ -f "$VERSION_MARKER" ]] && installed=$(cat "$VERSION_MARKER")

if [[ ! -x "$APP_HOME/usr/bin/dot" || "$installed" != "$VERSION" ]]; then
    if [[ -n "$installed" && "$installed" != "$VERSION" ]]; then
        echo "[graphviz-bootstrap] switching version: '$installed' -> '$VERSION'"
        rm -rf "$DEB_CACHE"
        mkdir -p "$DEB_CACHE"
    fi
    if ! ls "$DEB_CACHE"/graphviz_*.deb >/dev/null 2>&1; then
        echo "[graphviz-bootstrap] downloading graphviz $VERSION .debs"
        # apt-get download tries to drop privileges to user `_apt` for
        # the fetch and emits a cosmetic warning when the cwd isn't
        # readable by `_apt`. The download still succeeds.
        ( cd "$DEB_CACHE" && apt-get download "graphviz=$VERSION" "${LIB_PACKAGES[@]}" )
    fi
    echo "[graphviz-bootstrap] installing to $APP_HOME"
    rm -rf "$APP_HOME.tmp" "$APP_HOME"
    mkdir -p "$APP_HOME.tmp"
    for deb in "$DEB_CACHE"/*.deb; do
        dpkg-deb -x "$deb" "$APP_HOME.tmp"
    done
    mv "$APP_HOME.tmp" "$APP_HOME"

    # config6 (graphviz's plugin registry) is generated by `dot -c`
    # post-install on a normal apt install — not shipped in the .deb.
    # Regenerate it now so dot can find its layout/render plugins.
    LIB_DIR="$APP_HOME/usr/lib/x86_64-linux-gnu"
    LD_LIBRARY_PATH="$LIB_DIR" GVBINDIR="$LIB_DIR/graphviz" \
        "$APP_HOME/usr/bin/dot" -c

    printf '%s' "$VERSION" > "$VERSION_MARKER"
fi

# Drop wrappers into ~/bin (already on PATH). Wrappers — not symlinks —
# because each invocation needs LD_LIBRARY_PATH (libs under the
# non-standard prefix) and GVBINDIR (plugin lookup path).
mkdir -p "$HOME/bin"
LIB_DIR="$APP_HOME/usr/lib/x86_64-linux-gnu"
PLUGIN_DIR="$LIB_DIR/graphviz"

for src in "$APP_HOME/usr/bin/"*; do
    [[ -x "$src" && ! -d "$src" ]] || continue
    name=$(basename "$src")
    cat > "$HOME/bin/$name" <<EOF
#!/usr/bin/env bash
export LD_LIBRARY_PATH="$LIB_DIR\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
export GVBINDIR="$PLUGIN_DIR"
exec "$src" "\$@"
EOF
    chmod +x "$HOME/bin/$name"
done
