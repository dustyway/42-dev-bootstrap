#!/usr/bin/env bash
# wx-bootstrap — install wxWidgets (built by CI) to sgoinfre so Erlang can be
# compiled with wx/observer support on machines without root access.
# Safe to run every login (idempotent: no-op when the version is already in place).
#
# Called by mise-bootstrap before `mise install` to set up KERL_CONFIGURE_OPTIONS.
# Prints the install path to stdout on success; all progress messages go to stderr.
#
# Usage:  wx-bootstrap [VERSION]
# Env override:  WX_BOOTSTRAP_REPO=owner/repo (defaults to dustyway/42-dev-bootstrap)

set -euo pipefail

VERSION="${1:-3.2.6}"
REPO="${WX_BOOTSTRAP_REPO:-dustyway/42-dev-bootstrap}"
ASSET="wx-${VERSION}-linux-x86_64.tar.gz"
URL="https://github.com/${REPO}/releases/download/wx-${VERSION}/${ASSET}"

SGO="$(ls -d /sgoinfre/goinfre/Perso/*"${USER}"* 2>/dev/null | head -n1)"
[[ -z "$SGO" ]] && { echo "[wx-bootstrap] sgoinfre path not found for $USER" >&2; exit 1; }

APP_HOME="$SGO/wx/${VERSION}"
TARBALL="$SGO/.cache/${ASSET}"
SHAFILE="$SGO/.cache/${ASSET}.sha256"
VERSION_MARKER="$APP_HOME/.wx-bootstrap-version"

mkdir -p "$(dirname "$TARBALL")" "$SGO/wx"

installed=""
[[ -f "$VERSION_MARKER" ]] && installed=$(cat "$VERSION_MARKER")

if [[ ! -x "$APP_HOME/bin/wx-config" || "$installed" != "$VERSION" ]]; then
    if [[ -n "$installed" && "$installed" != "$VERSION" ]]; then
        echo "[wx-bootstrap] switching version: '$installed' -> '$VERSION'" >&2
        rm -f "$TARBALL" "$SHAFILE"
    fi
    if [[ ! -s "$TARBALL" ]]; then
        echo "[wx-bootstrap] downloading $ASSET" >&2
        curl -fL --retry 3 -o "$TARBALL" "$URL"
        if curl -fsSL -o "$SHAFILE" "${URL}.sha256" 2>/dev/null; then
            (cd "$(dirname "$TARBALL")" && sha256sum -c "$(basename "$SHAFILE")") \
                || { echo "[wx-bootstrap] sha256 mismatch for $ASSET" >&2; rm -f "$TARBALL"; exit 1; }
        fi
    fi
    echo "[wx-bootstrap] installing wx ${VERSION} to $APP_HOME" >&2
    rm -rf "$APP_HOME.tmp" "$APP_HOME"
    mkdir -p "$APP_HOME.tmp"
    tar -xzf "$TARBALL" -C "$APP_HOME.tmp" --strip-components=1
    mv "$APP_HOME.tmp" "$APP_HOME"

    # wx-config and pkg-config .pc files embed the CI build prefix /opt/wx.
    # Patch them to the actual sgoinfre install path so KERL picks up correct
    # include/lib paths when compiling Erlang.
    #
    # wx-config is normally in bin/ but may land elsewhere depending on the
    # build; search the whole tree and ensure bin/wx-config resolves correctly.
    wx_cfg=$(find "$APP_HOME" -name "wx-config" -not -type d 2>/dev/null | head -1)
    if [[ -z "$wx_cfg" ]]; then
        echo "[wx-bootstrap] ERROR: wx-config not found after extraction" >&2
        echo "[wx-bootstrap] Tree (first 40 entries):" >&2
        find "$APP_HOME" -maxdepth 4 2>/dev/null | head -40 >&2 || true
        rm -rf "$APP_HOME"
        exit 1
    fi
    sed -i "s|/opt/wx|${APP_HOME}|g" "$wx_cfg"
    mkdir -p "$APP_HOME/bin"
    [[ "$wx_cfg" != "$APP_HOME/bin/wx-config" ]] && \
        ln -sf "$wx_cfg" "$APP_HOME/bin/wx-config"
    for pc in "$APP_HOME"/lib/pkgconfig/*.pc; do
        [[ -f "$pc" ]] && sed -i "s|/opt/wx|${APP_HOME}|g" "$pc"
    done

    printf '%s' "$VERSION" > "$VERSION_MARKER"
fi

# Print install path to stdout for capture by the caller.
echo "$APP_HOME"
